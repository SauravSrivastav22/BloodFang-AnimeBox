rules_version = '2';

// BloodFang cloud-sync security rules.
// Each signed-in user can read/write ONLY their own document at users/{uid}.
// No one can read anyone else's data, and unauthenticated access is denied.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
